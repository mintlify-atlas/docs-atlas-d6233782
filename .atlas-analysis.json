  "keyFeatures": [
    "Type-safe Go client for Gcore API",
    "Automatic pagination with ListAutoPaging",
    "Built-in retry logic with exponential backoff",
    "Comprehensive error handling with detailed error types",
    "Request options for customization and middleware support",
    "Support for file uploads and multipart requests",
    "Cloud computing resources (VMs, bare metal, Kubernetes)",
    "CDN resource management and configuration",
    "DNS zone and record management",
    "Object storage operations",
    "Video streaming services",
    "IAM and security management"
  ],
  "publicApiSurface": [
    "gcore.NewClient() - Main client constructor",
    "client.Cloud - Cloud computing services",
    "client.CDN - CDN resources and configuration",
    "client.DNS - DNS management",
    "client.Storage - Object storage",
    "client.Streaming - Video streaming",
    "client.IAM - Identity and access management",
    "client.WAAP - Web application and API protection",
    "client.Security - Security services",
    "client.Fastedge - Edge computing applications",
    "option.WithAPIKey() - API authentication",
    "option.WithMaxRetries() - Configure retry behavior",
    "option.WithRequestTimeout() - Set request timeouts",
    "option.WithMiddleware() - Add custom middleware",
    "ListAutoPaging() - Auto-pagination iterator",
    "gcore.Error - Structured error type"
  ]
